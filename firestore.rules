rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Wijn-collectie: valideer veldstructuur bij schrijven
    match /wijnen/{wijnId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasAll(['naam', 'wijnhuis', 'kleur'])
                               && request.resource.data.naam is string
                               && request.resource.data.naam.size() > 0
                               && request.resource.data.naam.size() < 300
                               && request.resource.data.wijnhuis is string
                               && request.resource.data.kleur in ['Rood', 'Wit', 'Rosé', 'Oranje'];
      allow delete: if true;
    }

    // Wijnhuizen-collectie: valideer veldstructuur bij schrijven
    match /wijnhuizen/{wijnhuisId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasAll(['naam', 'informatie'])
                               && request.resource.data.naam is string
                               && request.resource.data.naam.size() > 0
                               && request.resource.data.naam.size() < 200;
      allow delete: if true;
    }

    // Alles buiten deze twee collecties: geen toegang
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
